                </div>
                <button type="button" class="btn btn-ghost btn-sm" data-view="games">See All</button>
              </div>
              <div class="stack" id="dash-games"></div>
            </div>

            <div class="card">
              <div class="card-head">
                <div>
                  <h2 class="card-title">Latest Ice Read</h2>
                  <p class="card-copy">Your newest note on speed, curl, and quirks.</p>
                </div>
                <button type="button" class="btn btn-ghost btn-sm" data-view="ice">See All</button>
              </div>
              <div class="stack" id="dash-ice"></div>
            </div>
