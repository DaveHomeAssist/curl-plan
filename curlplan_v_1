  <script>
    const STORAGE_KEY = "curlplan-v1";
    const SCHEMA_VERSION = 2;
    const PROTOTYPE_KEYS = {
      events: "cp_events",
      games: "cp_games",
      practice: "cp_practice",
      ice: "cp_ice",
      planner: "cp_planner"
    };

    const emptyState = () => ({
      version: SCHEMA_VERSION,
      events: [],
      games: [],
      practice: [],
      ice: [],
      plannerEntries: {}
    });

    const demoState = () => ({
      version: SCHEMA_VERSION,
      events: [
        {
          id: createId(),
          title: "Wednesday League Night",
          type: "league",
          date: "2026-03-18",
          time: "19:00",
          rink: "Philadelphia Curling Club",
          team: "Hammer Time",
