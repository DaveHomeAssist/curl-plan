  </div>

  <div class="overlay" id="modal-game">
    <div class="modal-panel">
      <div class="modal-head">
        <div>
          <h2 class="modal-title" id="gameModalTitle">Log Game</h2>
          <p class="modal-copy">Structured scores with notes, position, and key-shot memory.</p>
        </div>
